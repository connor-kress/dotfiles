export pdf() {
    (evince "$@" > /dev/null 2>&1 & disown; true) > /dev/null 2>&1
}

export img() {
    (loupe "$@" > /dev/null 2>&1 & disown; true) > /dev/null 2>&1
}

export show() {
    ssh -t darbox "/var/lib/chat/show.sh 'connor'" 2>/dev/null
}

export send() {
    ssh -t darbox "/var/lib/chat/send.sh 'connor' 'mandar' '$1'" 2>/dev/null
}

export chatw() {
    sudo systemctl start ollama
    chat "$@"
    sudo systemctl stop ollama
}

export chat-med() {
    chat qwen3:1.7b
}

export chatw-med() {
    chatw qwen3:1.7b
}

export reencode() {
    ffmpeg -i "$1" -c:v libx264 -preset medium -crf 23 "$2"
}

export qwen3-server() {
    xdg-open http://127.0.0.1:8080
    llama-server \
      --model ~/models/qwen3-vl-2b/Qwen3VL-2B-Instruct-Q4_K_M.gguf \
      --mmproj ~/models/qwen3-vl-2b/mmproj-Qwen3VL-2B-Instruct-Q8_0.gguf \
      --host 127.0.0.1 \
      --port 8080 \
      --ctx-size 16384 \
      --threads 8
  }
